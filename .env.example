# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# VirusTotal API key (https://www.virustotal.com/)
VT_API_KEY=

# Set to 0 to disable VirusTotal scanning (local-only mode)
VT_ENABLED=1

# Email alert settings (leave blank to disable alerts)
EMAIL_SERVER=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ALERT_RECIPIENT=
